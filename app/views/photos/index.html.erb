<h1>写真一覧</h1>
<p><%= link_to "写真をアップロード", new_photo_path %></p>
<% if oauth_authorize_url.present? %>
  <p><%= link_to "MyTweetAppと連携", oauth_authorize_url %></p>
<% end %>

<% if @photos.any? %>
  <ul>
    <% @photos.each do |photo| %>
      <li>
        <strong><%= photo.title %></strong>
        <span><%= l(photo.created_at, format: :short) %></span>
        <% if photo.image.attached? %>
          <div><%= image_tag photo.image, width: 200 %></div>
        <% end %>
        <% if access_token.present? %>
          <div><%= button_to "ツイートする", photo_tweet_path(photo) %></div>
        <% end %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>写真はまだありません。</p>
<% end %>
